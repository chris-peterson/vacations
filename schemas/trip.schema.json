{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Trip Private Data",
  "type": "object",
  "required": ["trip", "version", "meta", "days", "dayDetails"],
  "properties": {
    "trip": {
      "type": "string",
      "pattern": "^\\d{4}/.+$",
      "description": "Trip identifier matching the path under 2026/"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "meta": {
      "type": "object",
      "properties": {
        "dates": { "type": "string" },
        "allTimesNote": { "type": "string" }
      }
    },
    "days": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["index", "date", "shortDate"],
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "date": { "type": "string", "description": "Full date for day header (e.g. 'Sat, April 11')" },
          "shortDate": { "type": "string", "description": "Short date for scrapbook (e.g. 'Sat, Apr 11')" },
          "after": { "type": ["string", "null"], "description": "ISO timestamp for live mode activation" },
          "cards": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "title"],
              "properties": {
                "type": { "enum": ["transit", "game"] },
                "icon": { "type": "string" },
                "title": { "type": "string" },
                "time": { "type": ["string", "null"], "description": "Display time (e.g. '4:55 PM')" },
                "timeNote": { "type": "string", "description": "Label after time (e.g. 'first pitch', 'depart')" },
                "subtitle": { "type": "string" },
                "sleep": { "type": "string" },
                "sleepIcon": { "type": "string" },
                "matchup": {
                  "type": "object",
                  "required": ["away", "home"],
                  "properties": {
                    "away": { "type": "string" },
                    "home": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "dayDetails": {
      "type": "array",
      "items": { "type": "string" },
      "description": "HTML strings for scrapbook content, one per day"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "label"],
        "properties": {
          "type": { "enum": ["train", "game", "lodging"] },
          "label": { "type": "string" },
          "location": { "type": "string" },
          "destination": { "type": "string" },
          "traveler": { "type": "string" },
          "time": { "type": "string", "description": "ISO 8601 datetime" },
          "direction": { "type": "string" },
          "arrival": { "type": "string", "description": "ISO 8601 datetime for train arrival" },
          "check_in": { "type": "string" },
          "check_in_position": { "type": "string" },
          "check_out": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
